# --- Database (CockroachDB) ---
# Local dev (docker compose):
DATABASE_URL=postgresql://root@cockroach:26257/defaultdb?sslmode=disable
# CockroachDB Cloud:
# DATABASE_URL=postgresql://<user>:<password>@<cluster-host>:26257/paperplanes?sslmode=verify-full

# --- AWS / Bedrock ---
AWS_REGION=us-east-1
# Local dev only — on EC2 use the instance profile instead of keys:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Amazon Nova (first-party) — bills via standard AWS consumption (no Marketplace
# payment-instrument block). Swap to us.anthropic.* Claude ids if that access is enabled.
BEDROCK_CHAT_MODEL_ID=us.amazon.nova-pro-v1:0
BEDROCK_FAST_MODEL_ID=us.amazon.nova-lite-v1:0
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
EMBED_DIM=1024

# --- S3 ---
S3_BUCKET=paperplanes-pdfs-380906049984

# --- CockroachDB Cloud Managed MCP Server ---
MCP_ENDPOINT=https://cockroachlabs.cloud/mcp
MCP_API_KEY=

# --- App ---
ENV=dev
MCP_CLUSTER_ID=
# API auth: when set, every /api data route requires
#   Authorization: Bearer <this value>
# Leave empty for local dev / CI / the eval suite (open API); a deployment MUST
# set a strong random value (e.g. `openssl rand -hex 32`).
APP_API_TOKEN=
MCP_MEMORY_DATABASE=paperplanes_prod
