# Production environment for the EC2 deployment.
# Copy to the REPO ROOT as `.env.prod` on the server and fill in real values.
# NEVER commit the filled-in file — it is gitignored.

# --- Public domain (Caddy auto-HTTPS) ---
DOMAIN=paperplanes.duckdns.org

# --- CockroachDB Cloud (the prod database must already exist: CREATE DATABASE paperplanes_prod) ---
# NOTE: CockroachDB Cloud signs with its OWN CA, so verify-full needs that cluster
# CA cert. Download it on the host and mount it into the backend container (see
# docs/DEPLOY.md); the compose file mounts it at /certs/cockroach-ca.crt. Point the
# URL at that path with sslrootcert:
DATABASE_URL=postgresql://<user>:<password>@<cluster-host>:26257/paperplanes_prod?sslmode=verify-full&sslrootcert=/certs/cockroach-ca.crt

# --- AWS / Bedrock ---
# Do NOT put AWS keys here: the EC2 instance profile supplies credentials via IMDSv2.
AWS_REGION=us-east-1
BEDROCK_CHAT_MODEL_ID=us.amazon.nova-pro-v1:0
BEDROCK_FAST_MODEL_ID=us.amazon.nova-lite-v1:0
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0
EMBED_DIM=1024

# --- S3 ---
S3_BUCKET=paperplanes-pdfs-380906049984

# --- CockroachDB Cloud Managed MCP Server ---
MCP_ENDPOINT=https://cockroachlabs.cloud/mcp
MCP_API_KEY=<mcp-service-account-key-scoped-to-mcp:read>
MCP_CLUSTER_ID=<cluster-id>
MCP_MEMORY_DATABASE=paperplanes_prod

# --- App ---
ENV=prod
# REQUIRED in production: every /api data route requires  Authorization: Bearer <this>
# Generate with:  openssl rand -hex 32
APP_API_TOKEN=<strong-random-token>
